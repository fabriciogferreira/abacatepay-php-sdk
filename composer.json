{
    "name": "abacatepay/php-sdk",
    "description": "A robust PHP SDK for integrating AbacatePay payment solutions into your applications.",
    "type": "library",
    "autoload": {
        "psr-4": {
            "AbacatePay\\": "src/"
        }
    },
    "autoload-dev": {
        "files": [
            "tests/v1/Helpers.php",
            "tests/v2/Helpers.php",
            "tests/v2/Body/Assertions.php",
            "tests/v2/Exception/Assertions.php"
        ]
    },
    "authors": [
        {
            "name": "Julimar Junior",
            "email": "julimargomesjr@hotmail.com"
        }
    ],
    "require": {
        "php": "^7.2.5 || ^8.0",
        "guzzlehttp/guzzle": "^7.9",
        "fakerphp/faker": "^1.24"
    },
    "require-dev": {
        "vlucas/phpdotenv": "^5.6",
        "pestphp/pest": "^3.8",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    }
}
